# Reference override only: Vite does not auto-load this root file. The client
# already defaults to /api/v2, and both Vite and nginx proxy /api.
VITE_API_BASE_URL=/api/v2
MINDFOLIO_ENV=development
MINDFOLIO_CORS_ORIGINS=http://localhost:5173
MINDFOLIO_MARKET_DATA_PATH=./data/market-catalog.json
MINDFOLIO_MARKET_CONTEXT_PATH=./data/market-context-2025-v1.json
DB_PASSWORD=change-this-before-deploy
# Container-network reference. Docker Compose constructs the API container's
# DATABASE_URL from DB_PASSWORD; export this only for commands running inside
# the Compose network. Local make dev-api uses an in-memory holdings store when
# DATABASE_URL is unset.
DATABASE_URL=postgresql://app:change-this-before-deploy@postgres:5432/mindfolio
AWS_REGION=us-east-1
# Local/hackathon authentication only. Never commit the real key.
AWS_BEARER_TOKEN_BEDROCK=replace-with-local-bedrock-bearer-token
MINDFOLIO_BEDROCK_ENABLED=false
MINDFOLIO_BEDROCK_MODEL_ID=openai.gpt-oss-120b-1:0
MINDFOLIO_INVITE_IDENTITIES=replace-with-random-code:LEO
MINDFOLIO_REPORT_TTL_HOURS=72
MINDFOLIO_SESSION_SECRET=replace-with-at-least-32-random-characters
MINDFOLIO_SESSION_TTL_HOURS=24
