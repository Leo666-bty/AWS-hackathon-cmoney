V2/apps/ai-training/outputs/

# Organizer-provided raw source package stays local unless redistribution is approved.
# (Now under V2/data/ — the active version owns the data. Built catalog is separate.)
V2/data/*.pdf
V2/data/Delivery_Hackathon_DataPackage_20260624/*.csv
